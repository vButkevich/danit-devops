Yurii Vilchynskyi 20:53
server {
listen 80;
server_name site1.local;

root /var/www/html/site1;
index index.html;

location / {
auth_basic "Restricted Access";
auth_basic_user_file /etc/nginx/.htpasswd;
try_files $uri $uri/ =404;
}
}