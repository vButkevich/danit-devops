# setup ssh-server
sudo apt update
sudo apt install opentssh-server -y

# check ssh status
sudo systemctl status ssh


# set up 2222 port and disable password authentication
#add or change configuration in /etc/ssh/sshd_config
sudo nano /etc/ssh/sshd_config

Port 2222
PermitRootLogin no
PasswordAuthentication no
PubkeyAuthentication yes
AllowUsers john

#check config
sudo sshd -t
sudo sshd -t -f /etc/ssh/sshd_config
sudo sshd -T | grep -E "port|permitrootlogin|passwordauthentication|pubkeyauthentication|allowusers"

# restart ssh service
sudo systemctl restart ssh

#check ssh status
sudo systemctl status ssh

#check ssh logs
sudo journalctl -u ssh -f
sudo tail -f /var/log/auth.log

#check ports
sudo ss -tulpn | grep ssh

#check sshd process
ps aux | grep sshd


